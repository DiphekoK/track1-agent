# --- what the harness actually injects at evaluation time ---
FIREWORKS_API_KEY=your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Per the participant FAQ, only the MiniMax and Kimi K series are allowed
# on Fireworks for this hackathon - real values get published on launch
# day, but should be from those two families. kimi-k2p5 below is a
# currently-live Kimi model for local testing; swap the second slot for
# a currently-live MiniMax model (check GET /v1/models) rather than
# trusting this placeholder to still be accurate by the time you read it.
ALLOWED_MODELS=accounts/fireworks/models/kimi-k2p5,accounts/fireworks/models/minimax-m1

# --- optional, local testing only, not read by the harness ---
# override which model gets called when the router escalates to Fireworks
# (defaults to the first entry in ALLOWED_MODELS if unset). Doesn't need
# to be MiniMax/Kimi - this only matters for your own local testing, since
# it's specifically absent on submission day (see agent.get_fireworks_model)
MODEL_EXPENSIVE=accounts/fireworks/models/kimi-k2p5
# only used if ROUTER_MODE=baseline
MODEL_CLASSIFY=accounts/fireworks/models/kimi-k2p5

# finetuned (default) | baseline | heuristic - see README
ROUTER_MODE=finetuned
# below this confidence the finetuned router defers to categories.py's
# heuristic instead of trusting its own (possibly coin-flip) call
ROUTER_CONFIDENCE_THRESHOLD=0.65
