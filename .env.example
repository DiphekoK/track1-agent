# --- what the harness actually injects at evaluation time ---
FIREWORKS_API_KEY=your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# real values published on launch day - per the FAQ this'll be from the
# MiniMax and Kimi K series, these are placeholders for local testing only
ALLOWED_MODELS=accounts/fireworks/models/kimi-k2-instruct,accounts/fireworks/models/minimax-m1

# --- optional, local testing only, not read by the harness ---
# override which model gets called when the router escalates to Fireworks
# (defaults to the first entry in ALLOWED_MODELS if unset)
MODEL_EXPENSIVE=accounts/fireworks/models/kimi-k2-instruct
# only used if ROUTER_MODE=baseline
MODEL_CLASSIFY=accounts/fireworks/models/kimi-k2-instruct

# finetuned (default) | baseline | heuristic - see README
ROUTER_MODE=finetuned
